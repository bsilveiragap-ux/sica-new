    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sobre Nós | Sica Creative</title>
    <meta name="description" content="Não somos uma agência genérica. Construímos sistemas de aquisição previsíveis para empresas que querem crescer com controlo e consistência.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="sobre.css">
</head>
<body>

