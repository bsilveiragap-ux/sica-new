                    <!-- Instagram -->
                    <a href="https://instagram.com/sicacreative" target="_blank" rel="noopener noreferrer" class="promo-link promo-link--instagram" title="Instagram">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <rect x="2" y="2" width="20" height="20" rx="4" fill="none" stroke="rgba(255, 255, 255, 0.85)" stroke-width="1.5"/>
                            <circle cx="12" cy="12" r="3" fill="none" stroke="rgba(255, 255, 255, 0.85)" stroke-width="1.5"/>
                            <circle cx="17.5" cy="6.5" r="1" fill="rgba(255, 255, 255, 0.85)"/>
                        </svg>
                    </a>

                    <!-- LinkedIn -->
                    <a href="https://linkedin.com/company/sicacreative" target="_blank" rel="noopener noreferrer" class="promo-link promo-link--linkedin" title="LinkedIn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <rect x="2" y="2" width="20" height="20" rx="2" fill="none" stroke="rgba(255, 255, 255, 0.85)" stroke-width="1.5"/>
                            <path d="M5.5 9v8.5M5.5 5.5a1 1 0 1 1 2 0 1 1 0 0 1-2 0" fill="none" stroke="rgba(255, 255, 255, 0.85)" stroke-width="1.2" stroke-linecap="round"/>
                            <path d="M9.5 9v8.5c0 0.5 0.5 1 1 1h2v-5c0-1 0.5-2 1.5-2 1 0 1.5 0.5 1.5 2v5h2v-5.5c0-2-0.5-3.5-2-3.5-1 0-1.5 0.5-2 1v-1" fill="none" stroke="rgba(255, 255, 255, 0.85)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>

                    <!-- English Flag -->
                    <a href="index-en.html" class="promo-link promo-link--flag" title="Switch to English">
                        <svg width="18" height="18" viewBox="0 0 60 30" fill="none" aria-hidden="true">
                            <rect width="60" height="30" fill="#012169"/>
                            <path d="M0 0L60 30M60 0L0 30" stroke="white" stroke-width="6"/>
