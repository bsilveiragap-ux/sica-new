                            <circle cx="12" cy="12" r="3" fill="none" stroke="rgba(255, 255, 255, 0.85)" stroke-width="1.5"/>
                            <circle cx="17.5" cy="6.5" r="1" fill="rgba(255, 255, 255, 0.85)"/>
