                    <!-- Instagram -->
                    <a href="https://instagram.com/sicacreative" target="_blank" rel="noopener noreferrer" class="promo-link promo-link--instagram" title="Instagram">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
