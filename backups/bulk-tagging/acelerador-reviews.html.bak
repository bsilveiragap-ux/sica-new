    <main>
        <!-- PRODUCT HERO -->
        <section class="product-hero">
            <div class="container product-hero-inner">

                <!-- LEFT: Image -->
                <div class="product-image-wrap">
                    <div class="product-image-frame">
                        <img src="assets/ferramentas/placa-nfc-thumbnail.jpg" alt="Placa NFC e QR Code para reviews Google numa clínica" loading="eager">
                    </div>
                    <div class="product-badge-physical">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Z" stroke="#34224d" stroke-width="1.8"/><path d="M16 3v4M8 3v4M16 17v4M8 17v4" stroke="#34224d" stroke-width="1.8" stroke-linecap="round"/></svg>
                        Produto Físico
                    </div>
                </div>

                <!-- RIGHT: Details -->
                <div class="product-details">
                    <div class="product-breadcrumb">
                        <a href="ferramentas.html">Ferramentas</a>
                        <span aria-hidden="true">›</span>
                        <span>Acelerador de Reviews Google</span>
                    </div>

                    <h1 class="product-title">Acelerador de Reviews Google <span>(NFC + QR)</span></h1>
                    <p class="product-tagline">Os seus clientes avaliam a sua clínica em menos de 10 segundos — sem procurar, sem digitar, sem fricção.</p>

                    <div class="product-price-block">
                        <strong class="product-price">49,90€</strong>
                        <span class="product-price-note">IVA incluído · Envio em 3–5 dias úteis</span>
                    </div>

                    <!-- Order fields -->
                    <div class="product-order-fields">
                        <div class="product-field-group">
                            <label for="company-name">Nome da empresa <span class="required-mark">*</span></label>
                            <input type="text" id="company-name" name="company_name" required>
                        </div>
                        <div class="product-field-group">
                            <label for="company-logo">Logotipo da empresa <span class="required-mark">*</span></label>
                            <div class="file-input-wrapper">
                                <input type="file" id="company-logo" name="company_logo" accept=".png,.jpg,.jpeg,.svg">
                            </div>
                        </div>
                    </div>

                    <!-- CTA -->
                    <!-- Substitua o href pelo link de pagamento Stripe ou Ifthenpay -->
                    <a href="#LINK-DE-PAGAMENTO" class="btn btn-primary btn-full product-cta" target="_blank" rel="noopener noreferrer">
                        Encomendar agora
                    </a>

                    <!-- Trust badges -->
                    <ul class="product-trust">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7l-11 11-5-5" stroke="#6f5aa3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Personalizado com o seu logo
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7l-11 11-5-5" stroke="#6f5aa3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Chip NFC pré-configurado
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7l-11 11-5-5" stroke="#6f5aa3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Compatível com iOS e Android
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7l-11 11-5-5" stroke="#6f5aa3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Pronto a colocar no balcão
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- HOW IT WORKS -->
        <section class="product-steps section">
            <div class="container">
                <div class="section-header">
                    <span class="section-label">Processo</span>
                    <h2>Como funciona</h2>
                    <p>Do pedido à mesa de receção em 3 passos simples.</p>
                </div>
                <div class="product-steps-grid">
                    <div class="product-step">
                        <div class="product-step-num">01</div>
                        <h3>Encomenda com os seus dados</h3>
                        <p>No checkout fornece o nome da empresa e faz upload do logótipo. Nenhum conhecimento técnico necessário.</p>
                    </div>
                    <div class="product-step">
                        <div class="product-step-num">02</div>
                        <h3>Configuramos e personalizamos</h3>
                        <p>A Sica Creative gera o link direto para as suas reviews, programa o chip NFC e imprime a placa com a sua identidade.</p>
                    </div>
                    <div class="product-step">
                        <div class="product-step-num">03</div>
                        <h3>Recebe e coloca</h3>
                        <p>A placa chega pronta. Coloca-a no balcão de receção e começa a receber avaliações nesse mesmo dia.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- SPECS -->
        <section class="product-specs-section">
            <div class="container product-specs-inner">
                <div class="product-specs-content">
                    <span class="section-label">Especificações</span>
                    <h2>Feita para durar</h2>
                    <p>Materiais premium e tecnologia NFC de alta velocidade para um resultado profissional que representa a sua marca.</p>
                </div>
                <div class="product-specs-table">
                    <dl class="specs-list">
                        <div class="spec-row">
                            <dt>Formato</dt>
                            <dd>A6 · 105 × 148 mm</dd>
                        </div>
                        <div class="spec-row">
                            <dt>Material</dt>
                            <dd>Acrílico rígido com acabamento premium</dd>
                        </div>
                        <div class="spec-row">
                            <dt>Chip NFC</dt>
                            <dd>NTAG215 (alta velocidade)</dd>
                        </div>
                        <div class="spec-row">
                            <dt>QR Code</dt>
                            <dd>Alta resolução · sempre visível</dd>
                        </div>
                        <div class="spec-row">
                            <dt>Compatibilidade</dt>
                            <dd>iOS (iPhone) e Android</dd>
                        </div>
                        <div class="spec-row">
                            <dt>Personalização</dt>
                            <dd>Logo + nome da empresa impressos</dd>
                        </div>
                        <div class="spec-row">
                            <dt>Envio</dt>
                            <dd>3–5 dias úteis · Portugal Continental</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </section>

        <!-- WHAT WE NEED FROM YOU -->
        <section class="product-requirements section">
            <div class="container">
                <div class="section-header">
                    <span class="section-label">O que precisamos de si</span>
                    <h2>Para personalizar a sua placa</h2>
                    <p>Após o pagamento, partilha connosco estes dois elementos e tratamos do resto.</p>
                </div>
                <div class="requirements-grid">
                    <div class="requirement-card">
                        <div class="requirement-icon">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3" stroke="#6f5aa3" stroke-width="1.8"/><path d="M3 9l4-4 4 4 4-4 4 4" stroke="#6f5aa3" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="14" r="2" stroke="#6f5aa3" stroke-width="1.8"/></svg>
                        </div>
                        <h3>Logótipo da empresa</h3>
                        <p>Ficheiro em formato PNG, JPG ou SVG. Quanto maior a resolução, melhor o resultado final na placa.</p>
                    </div>
                    <div class="requirement-card">
                        <div class="requirement-icon">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 7h18M3 12h18M3 17h12" stroke="#6f5aa3" stroke-width="1.8" stroke-linecap="round"/></svg>
                        </div>
                        <h3>Nome da empresa</h3>
                        <p>O nome que aparece na placa e que é usado para gerar o link direto para as suas avaliações no Google.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- FINAL CTA -->
        <section class="tools-transition">
            <div class="container tools-transition-inner">
                <span class="section-label" style="color: rgba(255,255,255,0.6);">Pronto para começar?</span>
                <h2 style="color: #ffffff;">Mais reviews. Mais confiança. Mais clientes.</h2>
                <p style="color: rgba(255,255,255,0.7); max-width: 480px; margin: 0 auto 36px;">Uma placa. Um toque. Uma avaliação 5 estrelas. É assim simples.</p>
                <!-- Substitua o href pelo link de pagamento -->
                <a href="#LINK-DE-PAGAMENTO" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Encomendar por 49,90€</a>
            </div>
        </section>
    </main>

