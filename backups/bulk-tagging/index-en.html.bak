        <section id="process" class="section section-process">
            <div class="container">
                <div class="section-header">
                    <span class="section-label">Our approach</span>
                    <h2>Our approach</h2>
                    <p>A clear process to turn investment into predictable acquisition and sustained growth.</p>
                </div>

                <div class="process-system" id="processSystem">
                    <div class="process-rail" aria-hidden="true">
                        <span class="process-rail-track"></span>
                        <span class="process-rail-progress" id="processRailProgress"></span>
                        <span class="process-rail-dot" id="processRailDot"></span>
                    </div>

                    <div class="process-flow">
                        <article class="process-item is-active" data-step="analise">
                            <span class="process-step-index">01</span>
                            <h3>Analysis</h3>
                            <p>We audit channels, offer and funnel to identify where you're losing margin and scale opportunities.</p>
                        </article>

                        <article class="process-item" data-step="estrategia">
                            <span class="process-step-index">02</span>
                            <h3>Strategy</h3>
                            <p>We define an acquisition plan with measurable objectives, clear priorities and results-driven execution.</p>
                        </article>

                        <article class="process-item" data-step="crescimento">
                            <span class="process-step-index">03</span>
                            <h3>Growth</h3>
                            <p>Continuous optimization to increase revenue predictably, maintaining cost control and lead quality.</p>
                        </article>
                    </div>
                </div>
            </div>
        </section>

